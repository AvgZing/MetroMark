# Production profile (hosting machine)
APP_ENV=production
PORT=8080
SUPABASE_URL=https://your-prod-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_prod_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_prod_supabase_service_role_key
SUPABASE_DB_SIZE_RPC=metromark_database_size_bytes

# Local PostgreSQL/PostGIS cache storage for transit data.
# Keep this in a machine-local .env file that is not committed.
METROMARK_LOCAL_PGHOST=127.0.0.1
METROMARK_LOCAL_PGPORT=5432
METROMARK_LOCAL_PGUSER=postgres
METROMARK_LOCAL_PGPASSWORD=replace_with_local_postgres_password
METROMARK_LOCAL_PGDATABASE=metromark_cache
METROMARK_LOCAL_PGSSL=disable

TRANSITLAND_API_KEY=replace_with_transitland_api_key
TRANSIT_CACHE_TTL_HOURS=2160
TRANSIT_CACHE_STALE_DAYS=30
LINE_VIEW_ORDERING_VOTE_THRESHOLD=5

HARVEST_ENABLED=1
HARVEST_DAILY_REST_LIMIT=250
HARVEST_DAILY_VECTOR_LIMIT=2500
HARVEST_DAILY_ROUTING_LIMIT=250
HARVEST_BATCH_CITY_LIMIT=3
HARVEST_ROUTE_STOP_BATCH_SIZE=12
HARVEST_CORE_CITY_SLUGS=seattle,new-york,san-francisco,paris,london,chicago,minneapolis-st-paul,vancouver-bc,portland,los-angeles

ADMIN_USERNAME=replace_with_admin_username
ADMIN_PASSWORD=replace_with_admin_password
BACKUP_OUTPUT_DIR=data/backups/prod
