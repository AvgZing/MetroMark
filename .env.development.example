# Development profile (safe local testing)
APP_ENV=development
PORT=8080
SUPABASE_URL=https://your-dev-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_dev_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_dev_supabase_service_role_key
SUPABASE_DB_SIZE_RPC=metromark_database_size_bytes

TRANSITLAND_API_KEY=replace_with_transitland_api_key
TRANSIT_CACHE_TTL_HOURS=72
TRANSIT_CACHE_STALE_DAYS=7

# Keep harvest off in development unless you are explicitly testing it.
HARVEST_ENABLED=0
HARVEST_DAILY_REST_LIMIT=250
HARVEST_DAILY_VECTOR_LIMIT=2500
HARVEST_DAILY_ROUTING_LIMIT=250
HARVEST_BATCH_CITY_LIMIT=2
HARVEST_ROUTE_STOP_BATCH_SIZE=6
HARVEST_CORE_CITY_SLUGS=seattle,new-york,san-francisco,chicago

ADMIN_OVERRIDE_KEY=
ADMIN_STATS_KEY=
BACKUP_OUTPUT_DIR=data/backups/dev
