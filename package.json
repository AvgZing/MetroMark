{
  "name": "metromark",
  "version": "0.1.0",
  "private": true,
  "description": "MetroMark MVP - global transit explorer with line filters and station completion tracking",
  "main": "server/index.js",
  "scripts": {
    "start": "npm run start:dev",
    "start:prod": "set METROMARK_ENV_FILE=.env.production&& node server/index.js",
    "start:dev": "set METROMARK_ENV_FILE=.env.development&& node --watch server/index.js",
    "dev": "node --watch server/index.js",
    "check": "node --check server/index.js",
    "harvest:core": "set METROMARK_ENV_FILE=.env.development&& node scripts/harvest-core.js",
    "harvest:core:prod": "set METROMARK_ENV_FILE=.env.production&& node scripts/harvest-core.js",
    "backup:nonrecoverable": "set METROMARK_ENV_FILE=.env.development&& node scripts/backup-nonrecoverable.js",
    "backup:nonrecoverable:prod": "set METROMARK_ENV_FILE=.env.production&& node scripts/backup-nonrecoverable.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pbf": "^4.0.1",
    "pg": "^8.20.0"
  }
}
