# Server
PORT=8080
APP_ENV=development
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
SUPABASE_DB_SIZE_RPC=metromark_database_size_bytes

# Transit data
TRANSITLAND_API_KEY=replace_with_transitland_api_key
TRANSITLAND_REQUEST_TIMEOUT_MS=15000
TRANSITLAND_REQUEST_RETRIES=1
TRANSIT_CACHE_TTL_HOURS=2160
TRANSIT_CACHE_STALE_DAYS=30
ROUTE_CATALOG_MAX_RESULTS=220
ROUTE_STOP_PAGE_LIMIT=220
ROUTE_STOP_MAX_RESULTS=1400
ROUTE_HEADWAY_TIMEOUT_MS=22000
ROUTE_HEADWAY_CACHE_TTL_HOURS=72
STOP_ASSIGNMENT_MAX_METERS=140
STOP_DEDUP_MAX_METERS=55
STATION_HUB_MAX_METERS=220
STATION_HUB_SNAP_MAX_METERS=180
BBOX_MAX_SPAN_DEGREES=2.2
BBOX_DEFAULT_STEP_DEGREES=0.03

# Demo test account seeded automatically on first run
DEMO_USER_EMAIL=demo@metromark.local
DEMO_USER_PASSWORD=demo1234
DEMO_USER_NAME=Demo Rider

# Optional manual override API guard
ADMIN_OVERRIDE_KEY=

# Optional internal admin stats endpoint guard
ADMIN_STATS_KEY=

# Background harvesting and quotas
HARVEST_ENABLED=1
HARVEST_DAILY_REST_LIMIT=250
HARVEST_DAILY_VECTOR_LIMIT=2500
HARVEST_DAILY_ROUTING_LIMIT=250
HARVEST_BATCH_CITY_LIMIT=3
HARVEST_ROUTE_LIMIT_PER_CITY=150
HARVEST_ROUTE_STOP_BATCH_SIZE=12
HARVEST_CORE_CITY_SLUGS=seattle,new-york,san-francisco,paris,london,chicago,minneapolis-st-paul,vancouver-bc,portland,los-angeles

# Background backup output folder (Windows Task Scheduler friendly)
BACKUP_OUTPUT_DIR=data/backups
